---
import Layout from "../layouts/layout.astro";
import { supabase } from "../lib/supabase";
import ImageCard from "../components/ImageCard.astro";

// Fetch photos for 'wallpaper' category
const { data: photos, error } = await supabase
  .from('galeria_fotos')
  .select('*')
  .eq('categoria', 'wallpaper')
  .order('created_at', { ascending: false });

if (error) {
  console.error("Error fetching wallpaper photos:", error);
}
---

<Layout title="RONAP - Wallpapers">
  <main class="min-h-screen bg-black pt-24 pb-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header Section -->
      <div class="mb-12 text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">
          Nuestros <span class="text-emerald-500">Wallpapers</span>
        </h1>
        <p class="text-zinc-400 max-w-2xl mx-auto text-lg">
          Lleva la belleza de Ronap contigo. Fondos de pantalla optimizados para tus dispositivos.
        </p>
      </div>

      <!-- Gallery Grid -->
      {photos && photos.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 md:gap-8">
          {photos.map((photo) => (
            <ImageCard 
              title={photo.nombre}
              description={photo.descripcion}
              url={photo.url_imagen}
              category="Wallpaper"
            />
          ))}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 mb-4 text-zinc-700">
             <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
             </svg>
          </div>
          <h2 class="text-xl font-medium text-zinc-300">Aún no hay wallpapers disponibles</h2>
          <p class="text-zinc-500 mt-2">Estamos preparando capturas increíbles para tu pantalla.</p>
        </div>
      )}
    </div>
  </main>
</Layout>