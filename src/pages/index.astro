---
import layout from "../layouts/layout.astro";
---

<layout title="RONAP - Monitoreo">
  <main class="min-h-[60vh] flex items-center justify-center py-12 px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-6xl">
      <!-- Wallpapers -->
      <a
        href="/wallpapers"
        class="group relative overflow-hidden rounded-3xl bg-white shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 flex flex-col items-center justify-center p-6 sm:p-8 aspect-[16/9] md:aspect-auto md:h-80 border-2 border-gray-50 hover:border-[#d4a373]"
      >
        <div class="mb-4 md:mb-6 rounded-2xl bg-[#fdfbf7] p-3 md:p-4 group-hover:bg-[#d4a373]/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12 text-[#1a4d2e]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        </div>
        <h2 class="text-xl md:text-2xl font-black text-[#1a4d2e] uppercase tracking-tighter">Wallpapers</h2>
        <p class="mt-1 md:mt-2 text-gray-500 text-center text-xs md:text-sm font-medium">Descarga fondos exclusivos</p>
      </a>

      <!-- Cámara Trampa -->
      <a
        href="/camaras"
        class="group relative overflow-hidden rounded-3xl bg-[#1a4d2e] shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 flex flex-col items-center justify-center p-6 sm:p-8 aspect-[16/9] md:aspect-auto md:h-80"
      >
        <div class="mb-4 md:mb-6 rounded-2xl bg-white/10 p-3 md:p-4 group-hover:bg-white/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
        </div>
        <h2 class="text-xl md:text-2xl font-black text-white uppercase tracking-tighter">Cámara Trampa</h2>
        <p class="mt-1 md:mt-2 text-white/70 text-center text-xs md:text-sm font-medium">Observa la fauna silvestre</p>
      </a>

      <!-- Videos -->
      <a
        href="/videos"
        class="group relative overflow-hidden rounded-3xl bg-white shadow-lg hover:shadow-xl transition-all duration-500 hover:-translate-y-2 flex flex-col items-center justify-center p-6 sm:p-8 aspect-[16/9] md:aspect-auto md:h-80 border-2 border-gray-50 hover:border-[#d4a373]"
      >
        <div class="mb-4 md:mb-6 rounded-2xl bg-[#fdfbf7] p-3 md:p-4 group-hover:bg-[#d4a373]/10 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 md:w-12 md:h-12 text-[#1a4d2e]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
        </div>
        <h2 class="text-xl md:text-2xl font-black text-[#1a4d2e] uppercase tracking-tighter">Videos</h2>
        <p class="mt-1 md:mt-2 text-gray-500 text-center text-xs md:text-sm font-medium">Contenido multimedia</p>
      </a>
    </div>
  </main>
</layout>
