---
import logo_ronap from "../assets/logoronap.png";
---

<header class="sticky top-0 z-50 w-full bg-white/95 backdrop-blur-md shadow-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 h-20 md:h-24 flex items-center justify-center">
    <a href="/" class="group transition-transform duration-300 hover:scale-105">
      <img
        src={logo_ronap.src}
        alt="Logo RONAP WILDNET"
        class="h-14 md:h-16 w-auto object-contain"
      />
    </a>
  </div>
</header>
